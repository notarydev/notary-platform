{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisionevidence.org/schemas/dep/0.1/evidence-bundle.schema.json",
  "title": "DEP Evidence Bundle",
  "allOf": [
    {"$ref": "common.schema.json#/$defs/resourceCore"},
    {
      "type": "object",
      "required": ["manifest_digest", "subjects", "declared_omissions", "sealed_at"],
      "properties": {
        "manifest_digest": {"$ref": "common.schema.json#/$defs/digest"},
        "subjects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["resource_ref", "digest"],
            "properties": {
              "resource_ref": {"type": "string", "format": "uri"},
              "digest": {"$ref": "common.schema.json#/$defs/digest"}
            },
            "additionalProperties": false
          }
        },
        "declared_omissions": {"type": "array", "items": {"type": "string"}},
        "custody_events": {"type": "array", "items": {"type": "object"}},
        "sealed_at": {"type": "string", "format": "date-time"}
      }
    }
  ],
  "unevaluatedProperties": false
}
