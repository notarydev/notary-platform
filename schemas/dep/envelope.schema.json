{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dep://schema/envelope",
  "title": "DEP Envelope",
  "description": "Internal envelope used to validate and ingest a DEP resource reference.",
  "type": "object",
  "required": ["$schema", "id", "version", "resource", "provenance", "digest"],
  "properties": {
    "$schema": {"const": "dep://schema/envelope"},
    "id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "resource": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {"type": "string", "minLength": 1},
        "id": {"type": "string", "minLength": 1},
        "provider_id": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["collected_at"],
      "properties": {
        "collected_at": {"type": "string", "format": "date-time"},
        "received_at": {"type": "string", "format": "date-time"},
        "source_ref": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "digest": {
      "type": "object",
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {"const": "sha256"},
        "value": {"type": "string", "pattern": "^sha256:[A-Za-z0-9_-]+$"}
      },
      "additionalProperties": false
    },
    "epistemic_status": {
      "type": "string",
      "enum": [
        "observed",
        "asserted_by_provider",
        "customer_confirmed",
        "derived",
        "inferred",
        "missing",
        "conflicted"
      ]
    },
    "relationships": {"type": "array", "items": {"type": "object"}},
    "signature": {"type": "object"}
  },
  "additionalProperties": false
}
