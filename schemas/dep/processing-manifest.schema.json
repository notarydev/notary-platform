{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisionevidence.org/schemas/dep/0.1/processing-manifest.schema.json",
  "title": "DEP Processing Manifest",
  "allOf": [
    {"$ref": "common.schema.json#/$defs/resourceCore"},
    {
      "type": "object",
      "required": ["input_refs", "context_binding_refs", "operations", "started_at", "completed_at"],
      "properties": {
        "input_refs": {"type": "array", "items": {"type": "string", "format": "uri"}},
        "context_binding_refs": {"type": "array", "items": {"type": "string", "format": "uri"}},
        "parameters": {"type": "object"},
        "operations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["operation_ref", "version", "status"],
            "properties": {
              "operation_ref": {"type": "string", "format": "uri"},
              "version": {"type": "string"},
              "status": {"enum": ["executed", "skipped", "failed", "suppressed"]},
              "reason": {"type": "string"}
            },
            "additionalProperties": false
          }
        },
        "started_at": {"type": "string", "format": "date-time"},
        "completed_at": {"type": "string", "format": "date-time"}
      }
    }
  ],
  "unevaluatedProperties": false
}
