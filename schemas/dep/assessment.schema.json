{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dep://schema/assessment",
  "title": "DEP Assessment",
  "description": "An evaluator's judgment about a decision or evidence record. Assessments are deterministic outputs of evaluators.",
  "type": "object",
  "additionalProperties": false,
  "required": ["assessment_id", "der_id", "evaluator_id", "evaluator_version", "result", "timestamp"],
  "properties": {
    "assessment_id": { "type": "string" },
    "der_id": { "type": "string", "description": "Reference to the decision evidence record." },
    "evaluator_id": { "type": "string", "description": "Evaluator identifier." },
    "evaluator_version": { "type": "string", "description": "Evaluator contract version." },
    "result": {
      "type": "string",
      "enum": ["pass", "fail", "skip", "error", "inconclusive"],
      "description": "Evaluator verdict."
    },
    "evidence_links": {
      "type": "array",
      "items": { "type": "string" },
      "description": "References to evidence supporting this assessment."
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "method": { "type": "string", "description": "Evaluator method class." },
    "limitations": { "type": "string", "description": "Known limitations or caveats." },
    "details": { "type": "object", "description": "Evaluator-specific result details." }
  }
}
