{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisionevidence.org/schemas/dep/0.1/assessment.schema.json",
  "title": "DEP Assessment",
  "allOf": [
    {"$ref": "common.schema.json#/$defs/resourceCore"},
    {
      "type": "object",
      "required": ["evaluator_ref", "evaluator_version", "input_refs", "method", "status", "executed_at"],
      "properties": {
        "evaluator_ref": {"type": "string", "format": "uri"},
        "evaluator_version": {"type": "string"},
        "input_refs": {"type": "array", "items": {"type": "string", "format": "uri"}},
        "method": {"enum": ["deterministic", "heuristic", "statistical", "model_based", "human"]},
        "status": {"enum": ["executed", "skipped", "failed", "suppressed"]},
        "result": {"type": "object"},
        "missing_prerequisites": {"type": "array", "items": {"type": "string"}},
        "limitations": {"type": "array", "items": {"type": "string"}},
        "errors": {"type": "array", "items": {"type": "string"}},
        "executed_at": {"type": "string", "format": "date-time"}
      }
    }
  ],
  "unevaluatedProperties": false
}
